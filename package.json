{
  "name": "nwmhs-hubspot",
  "version": "1.0.0",
  "description": "NWMHS HubSpot CMS — Design Manager mirror",
  "private": true,
  "scripts": {
    "watch": "hs cms watch src/ src/ --account=NWMHS",
    "upload": "hs cms upload src/ src/ --account=NWMHS",
    "fetch": "hs cms fetch src/ src/ --account=NWMHS --overwrite",
    "fetch:hubspot": "hs cms fetch @hubspot @hubspot --account=NWMHS --overwrite",
    "list": "hs cms list --account=NWMHS"
  },
  "devDependencies": {
    "@hubspot/cli": "^8.3.0"
  }
}
