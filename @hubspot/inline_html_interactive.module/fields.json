    "type": "text",
    "visibility": {
      "controlling_field": "link_to",
      "controlling_value_regex": "tel",
      "operator": "EQUAL"
    },
    "required": true,
    "sortable": false,
    "validation_regex": "^((?:[-.\\/() ]*)[+](?:[-\\d.\\/() ]*)\\d(?:[-\\d.\\/() ]*))?((?:[-\\d.\\/() ]*)\\d(?:[-\\d.\\/() ]*))([,;](?:[-\\d.\\/() ]*)\\d(?:[-\\d.\\/() ]*))?$"
  },
  {
    "label": "File",
    "name": "file",
    "type": "file",
    "visibility": {
