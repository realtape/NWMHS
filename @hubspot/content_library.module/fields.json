[
  {
    "label": "Resources",
    "name": "group_resources",
    "type": "group",
    "group_occurrence_meta": {
      "featured_enabled": true,
      "featured_limit": 1
    },
    "occurrence": {
      "default": 9,
      "max": 20
    },
    "children": [
      {
        "label": "Name",
        "name": "title",
        "type": "text",
        "default": "Resource name"
      },
      {
        "label": "Description",
        "name": "description",
        "type": "text",
        "allow_new_line": true,
        "default": "A description of the resource being shared. Just a couple of sentences should be just right."
      },
      {
        "label": "Link text",
        "name": "link_text",
        "type": "text",
        "required": true,
        "default": "Download"
      },
      {
        "label": "Resource link",
        "name": "link",
        "type": "link",
        "inline_help_text": "File will download onto the user’s desktop after they click on the resource.",
        "show_advanced_rel_options": false,
        "supported_types": ["EXTERNAL", "CONTENT", "FILE", "CALL_TO_ACTION"],
        "default": {
          "url": {
            "content_id": null,
            "type": "FILE",
            "href": ""
          },
          "open_in_new_tab": false,
          "no_follow": false
        }
      },
      {
        "label": "Image",
        "name": "image_type",
        "type": "choice",
        "choices": [
          ["default", "Pick from a list of default images"],
          ["custom", "Use a custom image"]
        ],
        "display": "radio",
        "required": true,
        "default": "default"
      },
      {
        "label": "",
        "name": "default_image",
        "type": "choice",
        "visibility": {
          "controlling_field": "group_resources.image_type",
          "controlling_value_regex": "default",
          "operator": "EQUAL"
        },
        "choices": [
          ["ebook", "eBook"],
          ["pdf-document", "PDF Document"],
          ["infographic", "Infographic"],
          ["template", "Template"],
          ["guide", "Guide"],
          ["course", "Course"],
          ["webinar", "Webinar"],
          ["data-sheet", "Data sheet"],
          ["video", "Video"],
          ["blog-post", "Blog post"],
          ["whitepaper", "Whitepaper"],
          ["case-study", "Case study"]
        ],
        "default": "ebook"
      },
      {
        "label": "Custom image",
        "name": "custom_image",
        "type": "image",
        "visibility": {
          "controlling_field": "group_resources.image_type",
          "controlling_value_regex": "custom",
          "operator": "EQUAL"
        }
      }
    ],
    "default": [
      {
        "title": "eBook",
        "description": "A description of the resource being shared. Just a couple of sentences should be just right.",
        "link_text": "Download",
        "image_type": "default",
        "default_image": "ebook"
      },
      {
        "title": "PDF Document",
        "description": "A description of the resource being shared. Just a couple of sentences should be just right.",
        "link_text": "Download",
        "image_type": "default",
        "default_image": "pdf-document"
      },
      {
        "title": "Infographic",
        "description": "A description of the resource being shared. Just a couple of sentences should be just right.",
        "link_text": "Download",
        "image_type": "default",
        "default_image": "infographic"
      },
      {
        "title": "Template",
        "description": "A description of the resource being shared. Just a couple of sentences should be just right.",
        "link_text": "Download",
        "image_type": "default",
        "default_image": "template"
      },
      {
        "title": "Guide",
        "description": "A description of the resource being shared. Just a couple of sentences should be just right.",
        "link_text": "Download",
        "image_type": "default",
        "default_image": "guide"
      },
      {
        "title": "Course",
        "description": "A description of the resource being shared. Just a couple of sentences should be just right.",
        "link_text": "Download",
        "image_type": "default",
        "default_image": "course"
      },
      {
        "title": "Webinar",
        "description": "A description of the resource being shared. Just a couple of sentences should be just right.",
        "link_text": "Download",
        "image_type": "default",
        "default_image": "webinar"
      },
      {
        "title": "Data sheet",
        "description": "A description of the resource being shared. Just a couple of sentences should be just right.",
        "link_text": "Download",
        "image_type": "default",
        "default_image": "data-sheet"
      },
      {
        "title": "Video",
        "description": "A description of the resource being shared. Just a couple of sentences should be just right.",
        "link_text": "Download",
        "image_type": "default",
