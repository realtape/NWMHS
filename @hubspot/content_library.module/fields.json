  },
  {
    "label": "Default text",
    "name": "default_text",
    "type": "group",
    "locked": true,
    "children": [
      {
        "label": "Download aria label prefix",
        "name": "download_aria_label_prefix",
        "type": "text",
        "default": "Download"
      },
      {
        "label": "Content aria label prefix",
        "name": "content_aria_label_prefix",
        "type": "text",
        "default": "View [[resource_name]] content"
      },
      {
        "label": "External aria label prefix",
        "name": "external_aria_label_prefix",
        "type": "text",
        "default": "Open"
      },
      {
        "label": "In new tab aria label suffix",
        "name": "new_tab_aria_label_suffix",
        "type": "text",
        "default": "in new tab"
      }
    ]
  },
  {
    "label": "Styles",
    "name": "styles",
    "type": "group",
    "tab": "STYLE",
    "children": [
      {
        "label": "Layout",
        "name": "group_layout",
        "type": "group",
        "children": [
          {
            "label": "Style",
            "name": "style",
            "type": "choice",
            "choices": [
              ["cards", "Cards"],
              ["tiles", "Tiles"],
              ["minimal", "Minimal"]
            ],
            "display": "buttons",
            "preset": "layout",
            "required": true,
            "default": "cards"
          }
        ]
      },
      {
        "label": "Name",
        "name": "group_name",
        "type": "group",
        "children": [
          {
            "label": "Font",
            "name": "font",
            "type": "font",
            "default": {
              "size": 24,
              "size_unit": "px",
              "color": "#000"
            }
          }
        ]
      },
      {
        "label": "Description",
        "name": "group_description",
        "type": "group",
        "children": [
          {
            "label": "Font",
            "name": "font",
            "type": "font",
            "default": {
              "size": 16,
              "size_unit": "px",
              "color": "#000"
            }
          }
        ]
      },
      {
        "label": "Image",
        "name": "group_image",
        "type": "group",
        "children": [
          {
            "label": "Aspect ratio",
            "name": "aspect_ratio",
            "type": "choice",
            "choices": [
              ["1/1", "1:1"],
              ["4/3", "4:3"],
              ["16/9", "16:9"]
            ],
            "display": "select",
            "default": "1/1"
          },
          {
            "label": "Primary color",
            "name": "svg_primary",
            "type": "color",
            "help_text": "Adjust the colors of the default graphics.",
            "default": "#516747"
          },
          {
            "label": "Secondary color",
            "name": "svg_secondary",
            "type": "color",
            "help_text": "Adjust the colors of the default graphics.",
            "default": "#734E36"
          },
          {
            "label": "Tertiary color",
            "name": "svg_tertiary",
            "type": "color",
            "help_text": "Adjust the colors of the default graphics.",
            "default": "#878cab"
          }
        ]
      },
      {
        "label": "Link",
        "name": "group_link",
        "type": "group",
        "children": [
          {
            "label": "Default text color",
            "name": "default_text_color",
            "type": "color",
            "default": "#000"
          },
          {
            "label": "Hover text color",
            "name": "hover_text_color",
            "type": "color",
            "default": "#000"
          }
        ]
      }
    ]
  }
]
