  "tabs.content.default": {
    "message": "<p>जब ऐसा कॉन्टेंट अधिक मात्रा में होता है जिसे अलग-अलग श्रेणियों में अलग करने की आवश्यकता होती है, तो वेबसाइट पेज पर जानकारी को व्यवस्थित करने के लिए टैब्स एक प्रभावी तरीका होते हैं। अपने टैब को एक या दो शब्दों से लेबल करें जो जानकारी की प्रत्येक श्रेणी को परिभाषित करते हों।</p> <p>अपने टैब को स्टाइल करते समय, चुने गए टैब को ऐसे रंग से हाइलाइट करें जो आपके अचयनित टैब से अलग हो, ताकि आपके विज़िटर्स के लिए नेविगेट करना आसान हो जाए।</p>",
    "description": "",
    "placeholders": null
