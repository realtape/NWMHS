        "enabled_features": ["standard_emphasis", "alignment"],
        "inline_help_text": "If <strong>Settings &#8594; Hover functionality</strong> is set to <strong>&ldquo;Show overlay&rdquo;</strong> this message will display on hover. Keep text brief for best results."
